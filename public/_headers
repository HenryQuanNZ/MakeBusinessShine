# Hashed Astro assets (CSS/JS/fonts) are immutable — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static brand assets — cache for a day.
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon.ico
  Cache-Control: public, max-age=86400
/og.svg
  Cache-Control: public, max-age=86400

# Search engine files — revalidate hourly.
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-*.xml
  Cache-Control: public, max-age=3600

# HTML pages — short cache, always revalidate so deploys land instantly.
/*
  Cache-Control: public, max-age=300, must-revalidate
