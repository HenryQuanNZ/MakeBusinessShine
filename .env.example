# Copy this file to .env and fill in the values you need locally.
# In Cloudflare Pages, set these as environment variables in the project
# settings (the PUBLIC_ prefix is what makes them available at build time).

# Cloudflare Web Analytics beacon token.
# Get this from: Cloudflare dashboard -> Web Analytics -> your site -> Snippet.
# It is the "token" value in the data-cf-beacon JSON attribute.
# When unset, no analytics script is injected.
PUBLIC_CF_BEACON_TOKEN=
