---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, switchLanguageUrl } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/og.svg' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en-NZ';
const altLang = lang === 'en' ? 'zh' : 'en';

const site = Astro.site ?? new URL('https://makebusinessshine.co.nz');
const canonical = new URL(Astro.url.pathname, site);
const altHref = new URL(switchLanguageUrl(Astro.url.pathname, altLang), site);
const ogUrl = new URL(ogImage, site);
const ogImageType = ogImage.endsWith('.svg')
  ? 'image/svg+xml'
  : ogImage.endsWith('.jpg') || ogImage.endsWith('.jpeg')
    ? 'image/jpeg'
    : 'image/png';

const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={altLang === 'zh' ? 'zh-CN' : 'en-NZ'} href={altHref} />
    <link rel="alternate" hreflang="x-default" href={new URL(switchLanguageUrl(Astro.url.pathname, 'en'), site)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />
    <meta property="og:site_name" content="MakeBusinessShine" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />
  </head>
  <body class="bg-paper text-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:rounded-[4px] focus:bg-pounamu focus:px-3 focus:py-2 focus:text-paper"
    >
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    {
      cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token":"${cfBeaconToken}"}`}
        />
      )
    }
  </body>
</html>
