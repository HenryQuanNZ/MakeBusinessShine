---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import Button from '../components/Button.astro';

type Case = {
  name: string;
  industry: string;
  pkg: string;
  blurb: string;
  swatch: 'paper' | 'mono' | 'ink' | 'pounamu';
  href?: string;
};

const cases: Case[] = [
  {
    name: 'Aro Valley Plumbing',
    industry: 'Trades',
    pkg: 'Starter',
    blurb: 'One-page site with click-to-call, service area map, and after-hours rate clearly above the fold.',
    swatch: 'paper',
    href: 'https://henryquannz.github.io/aro-valley-plumbing/',
  },
  {
    name: 'Cuba Street Bao',
    industry: 'Food & beverage',
    pkg: 'Standard',
    blurb: 'Menu, opening hours, and order-ahead link. Loads in under a second on a 3G phone connection.',
    swatch: 'mono',
    href: 'https://henryquannz.github.io/five-page-demo/about.html',
  },
  {
    name: 'Tory & Nguyen Clinic',
    industry: 'Healthcare',
    pkg: 'Bilingual',
    blurb: 'English + 中文 site for a Vietnamese-Chinese GP practice. Online booking and bilingual intake form.',
    swatch: 'pounamu',
    href: 'https://henryquannz.github.io/bilingual-gp-demo/',
  },
];
---

<BaseLayout
  title="Work — MakeBusinessShine"
  description="Recent websites for Wellington local businesses: trades, food and beverage, healthcare. Bilingual where it matters."
>
  <section class="mx-auto max-w-[1100px] px-5 pb-12 pt-16 sm:px-6 sm:pt-24">
    <p class="font-mono text-xs uppercase tracking-widest text-pounamu">Work</p>
    <h1 class="mt-4 max-w-3xl text-3xl font-bold tracking-tight text-ink sm:text-5xl">
      A few recent builds.
    </h1>
    <p class="mt-5 max-w-2xl text-base text-ink/80 sm:text-lg">
      Real businesses, real sites — every one scored above 95 on Lighthouse mobile.
      Hover for the package used; click through for the live site.
    </p>
    <p class="mt-3 max-w-2xl font-mono text-xs text-ink/70">
      Note: case studies below are placeholder demos while the studio is starting up — real client work replaces them soon.
    </p>
  </section>

  <section class="mx-auto max-w-[1100px] px-5 pb-20 sm:px-6">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        cases.map((c) => (
          <WorkCard
            name={c.name}
            industry={c.industry}
            pkg={c.pkg}
            blurb={c.blurb}
            swatch={c.swatch}
            href={c.href}
          />
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-[1100px] px-5 pb-24 sm:px-6">
    <div class="rounded-[4px] border border-line bg-[var(--color-mono-bg)] p-8 sm:p-10">
      <h2 class="text-2xl font-semibold text-ink sm:text-3xl">Your business could be here next.</h2>
      <p class="mt-3 max-w-xl text-ink/80">
        I take on three builds per month so each one gets full attention.
        If this month is full, you'll know within a day.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <Button href="/contact" variant="primary">Start a project</Button>
        <Button href="/packages" variant="secondary">See packages</Button>
      </div>
    </div>
  </section>
</BaseLayout>
