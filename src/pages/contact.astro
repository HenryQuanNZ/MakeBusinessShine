---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const FORM_ACTION = 'https://formspree.io/f/mojzklan';

const timelines = {
  starter: [
    { when: 'Day 0', title: 'You send this form', body: 'I reply within one working day with a fixed quote, a delivery date, and any clarifying questions.' },
    { when: 'Day 1', title: 'Deposit + brief', body: '50% deposit locks the slot. A quick call and a one-page brief you sign off.' },
    { when: 'Day 2–3', title: 'Build on staging', body: 'Your single page comes together on a staging URL, with a short note from me each evening.' },
    { when: 'Day 4', title: 'Revision round', body: 'You send one consolidated list of changes. I work through them and send back for review.' },
    { when: 'Day 5', title: 'Ship', body: 'Final 50% paid, your page goes live on your domain with SSL, analytics, and a 30-day fix window.' },
  ],
  standard: [
    { when: 'Day 0', title: 'You send this form', body: 'I reply within one working day with a fixed quote, a delivery date, and any clarifying questions.' },
    { when: 'Day 1', title: 'Deposit + brief', body: '50% deposit locks the slot. We have a 30-minute call and I write a one-page brief you sign off.' },
    { when: 'Day 2–5', title: 'Build on staging', body: "You watch a staging URL update daily. I send a short note every evening so you're never wondering." },
    { when: 'Day 6', title: 'Revision round', body: 'You send one consolidated list of changes. I work through them and send back for review.' },
    { when: 'Day 7', title: 'Ship', body: 'Final 50% paid, site goes live on your domain with SSL, analytics, and a 30-day fix window.' },
  ],
  bilingual: [
    { when: 'Day 0', title: 'You send this form', body: 'I reply within one working day with a fixed quote, a delivery date, and any clarifying questions.' },
    { when: 'Day 1', title: 'Deposit + brief', body: '50% deposit locks the slot. We have a 30-minute call and I write a one-page brief you sign off.' },
    { when: 'Day 2–6', title: 'Build both languages', body: 'Five pages built on staging in English and 中文 — I write the Chinese copy myself, not Google Translate.' },
    { when: 'Day 7', title: 'Native copy review', body: 'We review the Chinese together so it reads naturally to a native speaker, not like a translation.' },
    { when: 'Day 8–9', title: 'Revision rounds', body: 'One consolidated list of changes per language. I work through both and send back for review.' },
    { when: 'Day 10', title: 'Ship', body: 'Final 50% paid, the bilingual site goes live with hreflang, SSL, analytics, and a 30-day fix window.' },
  ],
};

const defaultPkg = 'standard';
---

<BaseLayout
  title="Contact — MakeBusinessShine"
  description="Tell me about your business in two sentences. I reply within one working day with a fixed quote and a delivery date."
>
  <section class="mx-auto max-w-[1100px] px-5 pb-12 pt-16 sm:px-6 sm:pt-24">
    <p class="font-mono text-xs uppercase tracking-widest text-pounamu">Contact</p>
    <h1 class="mt-4 max-w-3xl text-3xl font-bold tracking-tight text-ink sm:text-5xl">
      Two sentences. One working day.
    </h1>
    <p class="mt-5 max-w-2xl text-base text-ink/80 sm:text-lg">
      Tell me about your business and what you need. I reply within one working day with a fixed quote
      and a delivery date — or an honest "I'm not the right person" if I'm not.
    </p>
  </section>

  <section class="mx-auto max-w-[1100px] px-5 pb-20 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr] lg:gap-12">
      <form
        action={FORM_ACTION}
        method="POST"
        class="space-y-5 rounded-[4px] border border-line bg-paper p-6 sm:p-7"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-ink">Your name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="mt-1.5 w-full rounded-[4px] border border-line bg-paper px-3 py-2.5 text-ink outline-none focus:border-pounamu"
          />
        </div>

        <div>
          <label for="business" class="block text-sm font-medium text-ink">Business name</label>
          <input
            type="text"
            id="business"
            name="business"
            required
            autocomplete="organization"
            class="mt-1.5 w-full rounded-[4px] border border-line bg-paper px-3 py-2.5 text-ink outline-none focus:border-pounamu"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-ink">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="mt-1.5 w-full rounded-[4px] border border-line bg-paper px-3 py-2.5 text-ink outline-none focus:border-pounamu"
          />
        </div>

        <div>
          <label for="budget" class="block text-sm font-medium text-ink">Budget</label>
          <select
            id="budget"
            name="budget"
            required
            class="mt-1.5 w-full rounded-[4px] border border-line bg-paper px-3 py-2.5 text-ink outline-none focus:border-pounamu"
          >
            <option value="">Pick a range</option>
            <option value="starter">Starter — around NZ$399</option>
            <option value="standard">Standard — around NZ$699</option>
            <option value="bilingual">Bilingual — around NZ$1,099</option>
            <option value="unsure">Not sure yet — talk it through</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-ink">What do you need?</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="mt-1.5 w-full rounded-[4px] border border-line bg-paper px-3 py-2.5 text-ink outline-none focus:border-pounamu"
            placeholder="Two sentences are enough. What do you do, and what's missing?"
          ></textarea>
        </div>

        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

        <Button type="submit" variant="primary">Send</Button>
        <p class="font-mono text-xs text-ink/70">
          Your details go to my inbox only. No newsletter, no tracking pixels.
        </p>
      </form>

      <aside>
        <header class="mb-5">
          <p class="font-mono text-xs uppercase tracking-wider text-pounamu">Timeline</p>
          <h2 data-timeline-heading class="mt-2 text-xl font-semibold text-ink sm:text-2xl">From form to live site.</h2>
        </header>
        {
          Object.entries(timelines).map(([slug, steps]) => (
            <ol class="space-y-4" data-pkg-timeline={slug} hidden={slug !== defaultPkg}>
              {steps.map((step) => (
                <li class="rounded-[4px] border border-line bg-paper p-4 sm:p-5">
                  <p class="font-mono text-xs uppercase tracking-wider text-pounamu">{step.when}</p>
                  <p class="mt-1.5 font-semibold text-ink">{step.title}</p>
                  <p class="mt-1.5 text-sm text-ink/80">{step.body}</p>
                </li>
              ))}
            </ol>
          ))
        }
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-[1100px] px-5 pb-24 sm:px-6">
    <div class="rounded-[4px] border border-line bg-[var(--color-mono-bg)] p-6 sm:p-8">
      <p class="font-mono text-xs uppercase tracking-wider text-pounamu">Direct</p>
      <h2 class="mt-2 text-xl font-semibold text-ink sm:text-2xl">Prefer email or chat?</h2>
      <ul class="mt-4 space-y-2 font-mono text-sm">
        <li>
          <span class="text-ink/70">Email&nbsp;&nbsp;</span>
          <a href="mailto:hello@makebusinessshine.com" class="text-pounamu">hello@makebusinessshine.com</a>
        </li>
      </ul>
    </div>
  </section>

  <script is:inline>
    (function () {
      const days = { starter: 5, standard: 7, bilingual: 10 };
      const heading = document.querySelector('[data-timeline-heading]');
      const budget = document.getElementById('budget');

      function showTimeline(pkg) {
        // Fall back to the default timeline for "unsure" or empty selections.
        const target = pkg in days ? pkg : 'standard';
        document.querySelectorAll('[data-pkg-timeline]').forEach((el) => {
          el.hidden = el.getAttribute('data-pkg-timeline') !== target;
        });
        if (heading) {
          heading.textContent =
            pkg in days
              ? `From form to live site in ${days[pkg]} working days.`
              : 'From form to live site.';
        }
      }

      // Prefill the dropdown and timeline from a ?package= link.
      const pkg = new URLSearchParams(location.search).get('package');
      if (pkg in days) {
        if (budget) budget.value = pkg;
        showTimeline(pkg);
      }

      // Keep the timeline in sync as the user changes the Budget dropdown.
      if (budget) budget.addEventListener('change', () => showTimeline(budget.value));
    })();
  </script>
</BaseLayout>
